# ============================================================
# SELIV — Variables d'environnement PRODUCTION
# Copier ce fichier en .env.prod et remplir toutes les valeurs
# NE PAS committer .env.prod dans Git
# ============================================================

# --- Domaine ---
DOMAIN=seliv.fr
CERTBOT_EMAIL=admin@seliv.fr

# --- Base de données ---
POSTGRES_USER=seliv
POSTGRES_PASSWORD=CHANGER_MOI_mot_de_passe_fort
POSTGRES_DB=seliv_db

# --- JWT ---
# Générer avec: openssl rand -hex 32
JWT_SECRET=CHANGER_MOI_secret_jwt_32_caracteres_minimum
JWT_EXPIRES_IN=7d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXX

# --- Resend (emails) ---
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@seliv.fr

# --- URLs publiques ---
# Le frontend appelle l'API via le navigateur du client
# En production avec nginx sur le même domaine :
NEXT_PUBLIC_API_URL=https://seliv.fr/api/v1
FRONTEND_URL=https://seliv.fr
NEXTAUTH_URL=https://seliv.fr

# --- Next.js ---
# Générer avec: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGER_MOI_secret_nextauth_32_caracteres

# --- Accès beta (phase de test) ---
# Laisser vide ou supprimer pour désactiver le code d'accès
# Le site sera bloqué derrière cette page de code tant que cette variable est définie
ACCESS_CODE=CHANGER_MOI_code_acces_test

# --- Environnement ---
NODE_ENV=production
